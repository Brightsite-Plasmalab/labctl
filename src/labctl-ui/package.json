{
	"name": "labctl-ui",
	"description": "Electron desktop UI for LabCTL serial devices",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"main": "electron/main.js",
	"scripts": {
		"dev": "electron . --dev",
		"build": "vite build",
		"package:mac": "npm run build && env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dir --publish never",
		"package:win": "npm run build && electron-builder --win dir --publish never",
		"package:win:x64": "npm run build && electron-builder --win dir --x64 --publish never",
		"start": "npm run build && electron .",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"build": {
		"appId": "com.brightsite.labctl",
		"productName": "LabCTL",
		"directories": {
			"output": "dist",
			"buildResources": "electron"
		},
		"files": [
			"build/**/*",
			"electron/**/*",
			"package.json"
		],
		"mac": {
			"target": [
				"dir"
			],
			"identity": null,
			"category": "public.app-category.developer-tools"
		},
		"win": {
			"target": [
				"dir"
			],
			"signAndEditExecutable": false
		}
	},
	"devDependencies": {
		"@emnapi/core": "^1.9.2",
		"@emnapi/runtime": "^1.9.2",
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.8.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.1.16",
		"bits-ui": "^2.17.3",
		"clsx": "^2.1.1",
		"electron": "^41.2.0",
		"electron-builder": "^26.8.1",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"serialport": "^13.0.0"
	}
}
